{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "module": "esnext",
    "moduleResolution": "node",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@assets": ["assets/*"],
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "styles/auth.css.ts"
  ],
  "exclude": [
    "app"
  ]
}
